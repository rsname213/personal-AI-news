{# templates/digest.html.j2 #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { background-color: #f9f9f9; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
    .wrapper { max-width: 600px; margin: 0 auto; padding: 24px; background-color: #ffffff; }
    .header-title { font-size: 22px; font-weight: 700; color: #111111; margin: 0 0 4px 0; }
    .header-date { font-size: 13px; color: #888888; margin: 0 0 32px 0; }
    .section-header { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #666666; border-bottom: 1px solid #e5e5e5; padding-bottom: 6px; margin: 32px 0 16px 0; }
    .article { margin-bottom: 24px; }
    .article-title { font-size: 16px; font-weight: 600; color: #111111; text-decoration: none; display: block; margin-bottom: 4px; }
    .article-meta { font-size: 12px; color: #888888; margin: 0 0 8px 0; }
    .article-summary { font-size: 14px; color: #333333; line-height: 1.6; margin: 0 0 8px 0; }
    .article-why { font-size: 13px; color: #555555; border-left: 3px solid #dddddd; padding-left: 10px; margin: 0; line-height: 1.5; }
    .article-no-summary { font-size: 13px; color: #888888; font-style: italic; }
    .footer { font-size: 11px; color: #aaaaaa; margin-top: 40px; border-top: 1px solid #eeeeee; padding-top: 16px; }
  </style>
</head>
<body>
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f9f9f9;">
    <tr>
      <td align="center" style="padding: 24px 16px;">
        <table class="wrapper" width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; background-color: #ffffff; padding: 32px;">
          <tr>
            <td>
              <p class="header-title">AI Briefing</p>
              <p class="header-date">{{ date }}</p>

              {% for category, articles in sections.items() %}
              {% if articles %}
              <p class="section-header">{{ category }}</p>
              {% for article in articles %}
              <table class="article" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td>
                    <a href="{{ article.url }}" class="article-title">{{ article.title }}</a>
                    <p class="article-meta">{{ article.source_name }} &middot; {{ article.published_at.strftime('%b %-d, %Y') }}</p>
                    {% if not article.summarization_failed %}
                    <p class="article-summary">{{ article.summary }}</p>
                    <p class="article-why"><strong>Why it matters:</strong> {{ article.why_it_matters }}</p>
                    {% else %}
                    <p class="article-no-summary">Summary unavailable &mdash; <a href="{{ article.url }}" style="color: #666666;">see article for details</a>.</p>
                    {% endif %}
                  </td>
                </tr>
              </table>
              {% endfor %}
              {% endif %}
              {% endfor %}

              <p class="footer">Generated {{ date }} &middot; Personal AI Briefing</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
